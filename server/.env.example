# Environment
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lumen_suite?schema=public"
# Required only by the isolated finance integration suite. The database name must contain "test".
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lumen_suite_test?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-dev
JWT_REFRESH_SECRET=change-me-refresh-secret-dev
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed super-admin
SEED_ADMIN_EMAIL=admin@erp.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Super Admin

# Frontend URL (for CORS + password reset links)
CLIENT_URL=http://localhost:5173
REPORT_STORAGE_DIR=./storage/reports
FINANCE_STORAGE_DIR=./storage/finance
ACCOUNTING_STORAGE_DIR=./storage/accounting

# Email (leave empty to use Ethereal in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Lumen Suite <noreply@erp.com>"
