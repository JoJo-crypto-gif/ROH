  currentEnrolmentId String            @map("current_enrolment_id")
  nextEnrolmentId    String?           @unique @map("next_enrolment_id")
  decision           PromotionDecision
  status             PromotionStatus   @default(PENDING)
  remarks            String?
  recommendedById    String?           @map("recommended_by_id")
  approvedById       String?           @map("approved_by_id")
  approvedAt         DateTime?         @map("approved_at")
  currentEnrolment   StudentEnrolment  @relation("CurrentEnrolment", fields: [currentEnrolmentId], references: [id], onDelete: Restrict)
  nextEnrolment      StudentEnrolment? @relation("NextEnrolment", fields: [nextEnrolmentId], references: [id], onDelete: SetNull)
  recommendedBy      User?             @relation("PromotionRecommender", fields: [recommendedById], references: [id], onDelete: SetNull)
  approvedBy         User?             @relation("PromotionApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([currentEnrolmentId])
  @@index([status])
  @@map("promotions")
}

model AcademicAuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("academic_audit_logs")
}
