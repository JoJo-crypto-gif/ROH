generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AcademicYearStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum TermStatus {
  PENDING
  ACTIVE
  CLOSED
}

enum EnrollmentStatus {
  PLANNED
  ACTIVE
  COMPLETED
  WITHDRAWN
  TRANSFERRED
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  WITHDRAWN
  TRANSFERRED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ReportStatus {
  DRAFT
  PUBLISHED
}

enum PromotionDecision {
  PROMOTE
  REPEAT
  GRADUATE
  WITHDRAW
  TRANSFER
}

enum PromotionStatus {
  PENDING
  APPROVED
  CANCELLED
}

enum SchoolStaffCategory {
  TEACHING
  ADMIN
  SUPPORT
}

enum SchoolStaffStatus {
  ACTIVE
  INACTIVE
}

enum FeeScheduleKind {
  STANDARD
  SUPPLEMENTAL
}

enum FeeScheduleStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
}

enum FeeApplicability {
  MANDATORY
  OPTIONAL
}

enum ChargeAdjustmentType {
  DISCOUNT
  WAIVER
  CHARGE_CREDIT
  CHARGE_DEBIT
}

enum FinanceDecisionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FeePaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
}

enum FeePaymentStatus {
  POSTED
  REVERSAL_PENDING
  REVERSED
}

enum CreditLotStatus {
  ACTIVE
  REVERSED
}

enum AccountingBookDomain {
  SCHOOL
  NGO
}

enum AccountingBookStatus {
  SETUP
  ACTIVE
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountSystemKey {
  ACCOUNTS_RECEIVABLE
  STUDENT_CREDITS
  DEFERRED_FEE_INCOME
  ACCOUNTS_PAYABLE
  FEE_WAIVERS
  OPENING_EQUITY
  CASH_OVER_SHORT
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  REVERSED
}

enum JournalSource {
  MANUAL
  OPENING
  FEE_CHARGE
  FEE_PAYMENT
  CREDIT_ALLOCATION
  FEE_ADJUSTMENT
  PAYMENT_REVERSAL
  TERM_RECOGNITION
  EXPENSE_APPROVAL
  EXPENSE_PAYMENT
  EXPENSE_REVERSAL
  CASH_COUNT
  RECONCILIATION
}

enum MoneyAccountType {
  CASH
  BANK
  MOBILE_MONEY
  CARD_CLEARING
}

enum ExpenseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PARTIALLY_PAID
  PAID
  REVERSED
}

enum ReconciliationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String  @map("password_hash")
  name         String
  avatarUrl    String? @map("avatar_url")
  active       Boolean @default(true)

  staffNo  String?   @unique @map("staff_no")
  phone    String?
  joinedAt DateTime? @default(now()) @map("joined_at")

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])

  schoolStaffProfile SchoolStaff?

  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  sectionsTaught         ClassSection[]          @relation("ClassTeacher")
  publishedReports       ReportCardVersion[]     @relation("ReportPublisher")
  recommendedActions     Promotion[]             @relation("PromotionRecommender")
  approvedActions        Promotion[]             @relation("PromotionApprover")
  auditEntries           AcademicAuditLog[]      @relation("AuditActor")
  submittedFeeSchedules  FeeSchedule[]           @relation("FeeScheduleSubmitter")
  publishedFeeSchedules  FeeSchedule[]           @relation("FeeSchedulePublisher")
  optionalFeeAssignments OptionalFeeAssignment[] @relation("OptionalFeeAssigner")
  requestedAdjustments   ChargeAdjustment[]      @relation("AdjustmentRequester")
  decidedAdjustments     ChargeAdjustment[]      @relation("AdjustmentDecisionMaker")
  recordedFeePayments    FeePayment[]            @relation("PaymentRecorder")
  creditAllocations      CreditAllocation[]      @relation("CreditAllocator")
  requestedReversals     PaymentReversal[]       @relation("ReversalRequester")
  decidedReversals       PaymentReversal[]       @relation("ReversalDecisionMaker")
  financeAuditEntries    FinanceAuditLog[]       @relation("FinanceAuditActor")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model SchoolStaff {
  id        String              @id @default(cuid())
  userId    String              @unique @map("user_id")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffNo   String              @unique @map("staff_no")
  phone     String?
  jobTitle  String?             @map("job_title")
  category  SchoolStaffCategory @default(TEACHING)
  status    SchoolStaffStatus   @default(ACTIVE)
  joinedAt  DateTime            @default(now()) @map("joined_at")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@index([category, status])
  @@map("school_staff")
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  builtIn     Boolean @default(false) @map("built_in")

  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model RolePermission {
  roleId     String @map("role_id")
  permission String
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model AcademicSettings {
  id               String   @id @default("default")
  defaultTermCount Int      @default(3) @map("default_term_count")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("academic_settings")
}

model SchoolProfile {
  id              String   @id @default("default")
  name            String   @default("Lumen School")
  motto           String?
  address         String?
  phone           String?
  email           String?
  logoUrl         String?  @map("logo_url")
  headteacherName String?  @map("headteacher_name")
  reportFooter    String?  @map("report_footer")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("school_profiles")
}

model AcademicYear {
  id        String             @id @default(cuid())
  name      String             @unique
  startDate DateTime           @map("start_date")
  endDate   DateTime           @map("end_date")
  termCount Int                @default(3) @map("term_count")
  status    AcademicYearStatus @default(DRAFT)

  terms                 Term[]
  sections              ClassSection[]
  curriculumSubjects    CurriculumSubject[]
  assessmentScheme      AssessmentScheme?
  calendarEvents        CalendarEvent[]
  enrolments            StudentEnrolment[]
  feeSchedules          FeeSchedule[]
  accountingFiscalYears AccountingFiscalYear[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("academic_years")
}

model Term {
  id             String       @id @default(cuid())
  name           String
  sequence       Int
  startDate      DateTime     @map("start_date")
  endDate        DateTime     @map("end_date")
  status         TermStatus   @default(PENDING)
  academicYearId String       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  attendance             Attendance[]
  assessmentResults      AssessmentResult[]
  reports                TermReport[]
  feeSchedules           FeeSchedule[]
  feeEffectiveEnrolments StudentEnrolment[] @relation("FeeEffectiveTerm")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([academicYearId, sequence])
  @@unique([academicYearId, name])
  @@index([status])
  @@map("terms")
}

model GradeLevel {
  id               String       @id @default(cuid())
  name             String       @unique
  code             String       @unique
  order            Int          @unique
  isFinal          Boolean      @default(false) @map("is_final")
  active           Boolean      @default(true)
  nextGradeLevelId String?      @map("next_grade_level_id")
  nextGradeLevel   GradeLevel?  @relation("GradeProgression", fields: [nextGradeLevelId], references: [id], onDelete: SetNull)
  previousLevels   GradeLevel[] @relation("GradeProgression")

  sections           ClassSection[]
  curriculumSubjects CurriculumSubject[]
  feeSchedules       FeeSchedule[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("grade_levels")
}

model ClassSection {
  id             String       @id @default(cuid())
  name           String
  capacity       Int
  active         Boolean      @default(true)
  academicYearId String       @map("academic_year_id")
  gradeLevelId   String       @map("grade_level_id")
  classTeacherId String?      @map("class_teacher_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  gradeLevel     GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)
  classTeacher   User?        @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)

  enrolments StudentEnrolment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([academicYearId, name])
  @@index([academicYearId, gradeLevelId])
  @@map("class_sections")
}

model Subject {
  id          String  @id @default(cuid())
  name        String  @unique
  code        String  @unique
  description String?
  active      Boolean @default(true)

  curriculumSubjects CurriculumSubject[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subjects")
}

model CurriculumSubject {
  id             String       @id @default(cuid())
  academicYearId String       @map("academic_year_id")
  gradeLevelId   String       @map("grade_level_id")
  subjectId      String       @map("subject_id")
  passMark       Float        @default(50) @map("pass_mark")
  sortOrder      Int          @default(0) @map("sort_order")
  active         Boolean      @default(true)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  gradeLevel     GradeLevel   @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  assessmentResults AssessmentResult[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([academicYearId, gradeLevelId, subjectId])
  @@index([academicYearId, gradeLevelId])
  @@map("curriculum_subjects")
}

model AssessmentScheme {
  id             String       @id @default(cuid())
  academicYearId String       @unique @map("academic_year_id")
  name           String       @default("Standard Assessment")
  totalMax       Float        @default(100) @map("total_max")
  locked         Boolean      @default(false)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  components AssessmentComponent[]
  gradeBands GradeBand[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("assessment_schemes")
}

model AssessmentComponent {
  id       String           @id @default(cuid())
  schemeId String           @map("scheme_id")
  name     String
  code     String
  maxScore Float            @map("max_score")
  sequence Int
  scheme   AssessmentScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  scores AssessmentScore[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([schemeId, code])
  @@unique([schemeId, sequence])
  @@map("assessment_components")
}

model GradeBand {
  id       String           @id @default(cuid())
  schemeId String           @map("scheme_id")
  minScore Float            @map("min_score")
  maxScore Float            @map("max_score")
  grade    String
  remark   String
  scheme   AssessmentScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([schemeId, grade])
  @@map("grade_bands")
}

model Student {
  id               String        @id @default(cuid())
  admissionNo      String        @unique @map("admission_no")
  firstName        String        @map("first_name")
  lastName         String        @map("last_name")
  gender           String
  dob              DateTime
  status           StudentStatus @default(ACTIVE)
  enrolledAt       DateTime      @default(now()) @map("enrolled_at")
  avatarUrl        String?       @map("avatar_url")
  
  // Primary Guardian
  guardianName     String        @map("guardian_name")
  guardianPhone    String        @map("guardian_phone")
  guardianRelation String        @map("guardian_relation")
  guardianEmail    String?       @map("guardian_email")
  
  // Secondary Guardian
  guardian2Name     String?      @map("guardian2_name")
  guardian2Phone    String?      @map("guardian2_phone")
  guardian2Relation String?      @map("guardian2_relation")
  guardian2Email    String?      @map("guardian2_email")
  
  // Emergency Contact
  emergencyName     String?      @map("emergency_name")
  emergencyPhone    String?      @map("emergency_phone")
  emergencyRelation String?      @map("emergency_relation")
  
  // Health & Demographics
  bloodGroup        String?      @map("blood_group")
  allergies         String?
  medicalNotes      String?      @map("medical_notes")
  boardingStatus    String       @default("DAY") @map("boarding_status")
  previousSchool    String?      @map("previous_school")

  address          String
  photoColor       String        @map("photo_color")

  enrolments  StudentEnrolment[]
  feePayments FeePayment[]
  creditLots  StudentCreditLot[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("students")
}

model StudentEnrolment {
  id                 String           @id @default(cuid())
  studentId          String           @map("student_id")
  classSectionId     String           @map("class_section_id")
  academicYearId     String           @map("academic_year_id")
  feeEffectiveTermId String?          @map("fee_effective_term_id")
  status             EnrollmentStatus @default(ACTIVE)
  completedAt        DateTime?        @map("completed_at")
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Restrict)
  classSection       ClassSection     @relation(fields: [classSectionId], references: [id], onDelete: Restrict)
  academicYear       AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  feeEffectiveTerm   Term?            @relation("FeeEffectiveTerm", fields: [feeEffectiveTermId], references: [id], onDelete: Restrict)

  attendance             Attendance[]
  assessmentResults      AssessmentResult[]
  reports                TermReport[]
  promotions             Promotion[]             @relation("CurrentEnrolment")
  incomingPromotion      Promotion?              @relation("NextEnrolment")
  feeCharges             StudentCharge[]
  optionalFeeAssignments OptionalFeeAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([studentId, academicYearId])
  @@index([classSectionId, status])
  @@map("student_enrolments")
}

model FeeItem {
  id                 String              @id @default(cuid())
  code               String              @unique
  name               String
  description        String?
  active             Boolean             @default(true)
  scheduleLines      FeeScheduleLine[]
  accountingMappings FeeAccountMapping[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@map("fee_items")
}

model FeeSchedule {
  id             String            @id @default(cuid())
  academicYearId String            @map("academic_year_id")
  termId         String            @map("term_id")
  gradeLevelId   String            @map("grade_level_id")
  kind           FeeScheduleKind   @default(STANDARD)
  sequence       Int               @default(1)
  name           String
  status         FeeScheduleStatus @default(DRAFT)
  submittedById  String?           @map("submitted_by_id")
  submittedAt    DateTime?         @map("submitted_at")
  publishedById  String?           @map("published_by_id")
  publishedAt    DateTime?         @map("published_at")
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  term           Term              @relation(fields: [termId], references: [id], onDelete: Restrict)
  gradeLevel     GradeLevel        @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)
  submittedBy    User?             @relation("FeeScheduleSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  publishedBy    User?             @relation("FeeSchedulePublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  lines          FeeScheduleLine[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@unique([academicYearId, termId, gradeLevelId, kind, sequence])
  @@index([status, academicYearId, termId])
  @@map("fee_schedules")
}

model FeeScheduleLine {
  id            String                  @id @default(cuid())
  scheduleId    String                  @map("schedule_id")
  feeItemId     String                  @map("fee_item_id")
  label         String
  amount        Decimal                 @db.Decimal(12, 2)
  dueDate       DateTime                @map("due_date")
  applicability FeeApplicability        @default(MANDATORY)
  schedule      FeeSchedule             @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  feeItem       FeeItem                 @relation(fields: [feeItemId], references: [id], onDelete: Restrict)
  assignments   OptionalFeeAssignment[]
  charges       StudentCharge[]
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  @@unique([scheduleId, feeItemId])
  @@map("fee_schedule_lines")
}

model OptionalFeeAssignment {
  id           String           @id @default(cuid())
  enrolmentId  String           @map("enrolment_id")
  lineId       String           @map("line_id")
  assignedById String?          @map("assigned_by_id")
  enrolment    StudentEnrolment @relation(fields: [enrolmentId], references: [id], onDelete: Restrict)
  line         FeeScheduleLine  @relation(fields: [lineId], references: [id], onDelete: Restrict)
  assignedBy   User?            @relation("OptionalFeeAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now()) @map("created_at")

  @@unique([enrolmentId, lineId])
  @@map("optional_fee_assignments")
}

model StudentCharge {
  id                 String              @id @default(cuid())
  enrolmentId        String              @map("enrolment_id")
  lineId             String              @map("line_id")
  amount             Decimal             @db.Decimal(12, 2)
  dueDate            DateTime            @map("due_date")
  enrolment          StudentEnrolment    @relation(fields: [enrolmentId], references: [id], onDelete: Restrict)
  line               FeeScheduleLine     @relation(fields: [lineId], references: [id], onDelete: Restrict)
  adjustments        ChargeAdjustment[]
  paymentAllocations PaymentAllocation[]
  creditAllocations  CreditAllocation[]
  createdAt          DateTime            @default(now()) @map("created_at")

  @@unique([enrolmentId, lineId])
  @@index([enrolmentId, dueDate])
  @@map("student_charges")
}

model ChargeAdjustment {
  id            String                @id @default(cuid())
  chargeId      String                @map("charge_id")
  type          ChargeAdjustmentType
  amount        Decimal               @db.Decimal(12, 2)
  reason        String
  status        FinanceDecisionStatus @default(PENDING)
  requestedById String?               @map("requested_by_id")
  decidedById   String?               @map("decided_by_id")
  decidedAt     DateTime?             @map("decided_at")
  charge        StudentCharge         @relation(fields: [chargeId], references: [id], onDelete: Restrict)
  requestedBy   User?                 @relation("AdjustmentRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  decidedBy     User?                 @relation("AdjustmentDecisionMaker", fields: [decidedById], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now()) @map("created_at")

  @@index([status, chargeId])
  @@map("charge_adjustments")
}

model FeePayment {
  id             String              @id @default(cuid())
  studentId      String              @map("student_id")
  amount         Decimal             @db.Decimal(12, 2)
  method         FeePaymentMethod
  status         FeePaymentStatus    @default(POSTED)
  transactionRef String?             @map("transaction_ref")
  idempotencyKey String              @unique @map("idempotency_key")
  recordedById   String?             @map("recorded_by_id")
  moneyAccountId String?             @map("money_account_id")
  postedAt       DateTime            @default(now()) @map("posted_at")
  student        Student             @relation(fields: [studentId], references: [id], onDelete: Restrict)
  recordedBy     User?               @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  moneyAccount   MoneyAccount?       @relation(fields: [moneyAccountId], references: [id], onDelete: Restrict)
  allocations    PaymentAllocation[]
  creditLot      StudentCreditLot?
  receipt        FeeReceipt?
  reversal       PaymentReversal?
  createdAt      DateTime            @default(now()) @map("created_at")

  @@index([studentId, postedAt])
  @@index([method, transactionRef])
  @@index([status, postedAt])
  @@index([method, postedAt])
  @@map("fee_payments")
}

model PaymentAllocation {
  id         String        @id @default(cuid())
  paymentId  String        @map("payment_id")
  chargeId   String        @map("charge_id")
  amount     Decimal       @db.Decimal(12, 2)
  reversedAt DateTime?     @map("reversed_at")
  payment    FeePayment    @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  charge     StudentCharge @relation(fields: [chargeId], references: [id], onDelete: Restrict)
  createdAt  DateTime      @default(now()) @map("created_at")

  @@unique([paymentId, chargeId])
  @@index([chargeId, reversedAt])
  @@map("payment_allocations")
}

model StudentCreditLot {
  id          String             @id @default(cuid())
  studentId   String             @map("student_id")
  paymentId   String             @unique @map("payment_id")
  amount      Decimal            @db.Decimal(12, 2)
  status      CreditLotStatus    @default(ACTIVE)
  student     Student            @relation(fields: [studentId], references: [id], onDelete: Restrict)
  payment     FeePayment         @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  allocations CreditAllocation[]
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([studentId, status])
  @@map("student_credit_lots")
}

model CreditAllocation {
  id            String           @id @default(cuid())
  creditLotId   String           @map("credit_lot_id")
  chargeId      String           @map("charge_id")
  amount        Decimal          @db.Decimal(12, 2)
  allocatedById String?          @map("allocated_by_id")
  reversedAt    DateTime?        @map("reversed_at")
  creditLot     StudentCreditLot @relation(fields: [creditLotId], references: [id], onDelete: Restrict)
  charge        StudentCharge    @relation(fields: [chargeId], references: [id], onDelete: Restrict)
  allocatedBy   User?            @relation("CreditAllocator", fields: [allocatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now()) @map("created_at")

  @@index([creditLotId, reversedAt])
  @@index([chargeId, reversedAt])
  @@map("credit_allocations")
}

model PaymentReversal {
  id            String                @id @default(cuid())
  paymentId     String                @unique @map("payment_id")
  reason        String
  status        FinanceDecisionStatus @default(PENDING)
  requestedById String?               @map("requested_by_id")
  decidedById   String?               @map("decided_by_id")
  decidedAt     DateTime?             @map("decided_at")
  payment       FeePayment            @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  requestedBy   User?                 @relation("ReversalRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  decidedBy     User?                 @relation("ReversalDecisionMaker", fields: [decidedById], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now()) @map("created_at")

  @@index([status])
  @@map("payment_reversals")
}

model FeeReceipt {
  id        String     @id @default(cuid())
  paymentId String     @unique @map("payment_id")
  number    String     @unique
  year      Int
  sequence  Int
  snapshot  Json
  pdfPath   String     @map("pdf_path")
  checksum  String
  payment   FeePayment @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  issuedAt  DateTime   @default(now()) @map("issued_at")

  @@unique([year, sequence])
  @@index([issuedAt])
  @@map("fee_receipts")
}

model ReceiptSequence {
  year       Int      @id
  lastNumber Int      @default(0) @map("last_number")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("receipt_sequences")
}

model FinanceAuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  actor      User?    @relation("FinanceAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("finance_audit_logs")
}

model AccountingBook {
  id             String                 @id @default(cuid())
  domain         AccountingBookDomain   @unique
  name           String
  status         AccountingBookStatus   @default(SETUP)
  cutoverAt      DateTime?              @map("cutover_at")
  activatedById  String?                @map("activated_by_id")
  activatedAt    DateTime?              @map("activated_at")
  accounts       Account[]
  fiscalYears    AccountingFiscalYear[]
  feeMappings    FeeAccountMapping[]
  methodMappings PaymentMethodAccount[]
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  @@map("accounting_books")
}

model AccountingFiscalYear {
  id              String                 @id @default(cuid())
  bookId          String                 @map("book_id")
  academicYearId  String                 @map("academic_year_id")
  name            String
  startDate       DateTime               @map("start_date")
  endDate         DateTime               @map("end_date")
  status          AccountingPeriodStatus @default(OPEN)
  book            AccountingBook         @relation(fields: [bookId], references: [id], onDelete: Restrict)
  academicYear    AcademicYear           @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  periods         AccountingPeriod[]
  journals        JournalEntry[]
  expenses        Expense[]
  journalSequence JournalSequence?
  expenseSequence ExpenseSequence?
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@unique([bookId, academicYearId])
  @@index([status, startDate, endDate])
  @@map("accounting_fiscal_years")
}

model AccountingPeriod {
  id           String                 @id @default(cuid())
  fiscalYearId String                 @map("fiscal_year_id")
  name         String
  sequence     Int
  startDate    DateTime               @map("start_date")
  endDate      DateTime               @map("end_date")
  status       AccountingPeriodStatus @default(OPEN)
  closedAt     DateTime?              @map("closed_at")
  closedById   String?                @map("closed_by_id")
  fiscalYear   AccountingFiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  journals     JournalEntry[]
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  @@unique([fiscalYearId, sequence])
  @@index([fiscalYearId, status])
  @@map("accounting_periods")
}

model Account {
  id           String              @id @default(cuid())
  bookId       String              @map("book_id")
  code         String
  name         String
  type         AccountType
  systemKey    AccountSystemKey?   @map("system_key")
  parentId     String?             @map("parent_id")
  active       Boolean             @default(true)
  book         AccountingBook      @relation(fields: [bookId], references: [id], onDelete: Restrict)
  parent       Account?            @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children     Account[]           @relation("AccountHierarchy")
  journalLines JournalLine[]
  moneyAccount MoneyAccount?
  feeMappings  FeeAccountMapping[]
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@unique([bookId, code])
  @@unique([bookId, systemKey])
  @@index([bookId, type, active])
  @@map("accounts")
}

model MoneyAccount {
  id               String                 @id @default(cuid())
  accountId        String                 @unique @map("account_id")
  name             String
  type             MoneyAccountType
  institution      String?
  accountNumber    String?                @map("account_number")
  active           Boolean                @default(true)
  account          Account                @relation(fields: [accountId], references: [id], onDelete: Restrict)
  methodMappings   PaymentMethodAccount[]
  feePayments      FeePayment[]
  expensePayments  ExpensePayment[]
  statementImports BankStatementImport[]
  statementLines   BankStatementLine[]
  cashCounts       CashCount[]
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@index([type, active])
  @@map("money_accounts")
}

model PaymentMethodAccount {
  bookId         String           @map("book_id")
  method         FeePaymentMethod
  moneyAccountId String           @map("money_account_id")
  book           AccountingBook   @relation(fields: [bookId], references: [id], onDelete: Restrict)
  moneyAccount   MoneyAccount     @relation(fields: [moneyAccountId], references: [id], onDelete: Restrict)

  @@id([bookId, method])
  @@map("payment_method_accounts")
}

model FeeAccountMapping {
  bookId          String         @map("book_id")
  feeItemId       String         @map("fee_item_id")
  incomeAccountId String         @map("income_account_id")
  book            AccountingBook @relation(fields: [bookId], references: [id], onDelete: Restrict)
  feeItem         FeeItem        @relation(fields: [feeItemId], references: [id], onDelete: Restrict)
  incomeAccount   Account        @relation(fields: [incomeAccountId], references: [id], onDelete: Restrict)

  @@id([bookId, feeItemId])
  @@map("fee_account_mappings")
}

model JournalSequence {
  fiscalYearId String               @id @map("fiscal_year_id")
  lastNumber   Int                  @default(0) @map("last_number")
  fiscalYear   AccountingFiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@map("journal_sequences")
}

model JournalEntry {
  id              String                 @id @default(cuid())
  fiscalYearId    String                 @map("fiscal_year_id")
  periodId        String?                @map("period_id")
  number          String?                @unique
  date            DateTime
  description     String
  status          JournalStatus          @default(DRAFT)
  source          JournalSource          @default(MANUAL)
  sourceKey       String?                @unique @map("source_key")
  metadata        Json?
  preparedById    String?                @map("prepared_by_id")
  submittedAt     DateTime?              @map("submitted_at")
  approvedById    String?                @map("approved_by_id")
  postedAt        DateTime?              @map("posted_at")
  reversalOfId    String?                @unique @map("reversal_of_id")
  reversedById    String?                @map("reversed_by_id")
  fiscalYear      AccountingFiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  period          AccountingPeriod?      @relation(fields: [periodId], references: [id], onDelete: Restrict)
  reversalOf      JournalEntry?          @relation("JournalReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversal        JournalEntry?          @relation("JournalReversal")
  lines           JournalLine[]
  sourceLinks     AccountingSourceLink[]
  expenseApproval Expense?               @relation("ExpenseApprovalJournal")
  expensePayments ExpensePayment[]
  cashCount       CashCount?
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@index([fiscalYearId, date, status])
  @@index([source, postedAt])
  @@map("journal_entries")
}

model JournalLine {
  id                    String                @id @default(cuid())
  journalId             String                @map("journal_id")
  accountId             String                @map("account_id")
  description           String?
  debit                 Decimal               @default(0) @db.Decimal(12, 2)
  credit                Decimal               @default(0) @db.Decimal(12, 2)
  studentId             String?               @map("student_id")
  journal               JournalEntry          @relation(fields: [journalId], references: [id], onDelete: Restrict)
  account               Account               @relation(fields: [accountId], references: [id], onDelete: Restrict)
  reconciliationMatches ReconciliationMatch[]
  createdAt             DateTime              @default(now()) @map("created_at")

  @@index([accountId, journalId])
  @@index([studentId])
  @@map("journal_lines")
}

model AccountingSourceLink {
  id         String       @id @default(cuid())
  journalId  String       @map("journal_id")
  entityType String       @map("entity_type")
  entityId   String       @map("entity_id")
  journal    JournalEntry @relation(fields: [journalId], references: [id], onDelete: Restrict)

  @@unique([journalId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("accounting_source_links")
}

model ExpenseSequence {
  fiscalYearId String               @id @map("fiscal_year_id")
  lastNumber   Int                  @default(0) @map("last_number")
  fiscalYear   AccountingFiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@map("expense_sequences")
}

model Expense {
  id                    String               @id @default(cuid())
  fiscalYearId          String               @map("fiscal_year_id")
  number                String               @unique
  payee                 String
  reference             String?
  date                  DateTime
  dueDate               DateTime?            @map("due_date")
  description           String
  status                ExpenseStatus        @default(DRAFT)
  total                 Decimal              @db.Decimal(12, 2)
  missingDocumentReason String?              @map("missing_document_reason")
  createdById           String?              @map("created_by_id")
  submittedAt           DateTime?            @map("submitted_at")
  approvedById          String?              @map("approved_by_id")
  approvedAt            DateTime?            @map("approved_at")
  rejectedById          String?              @map("rejected_by_id")
  rejectedAt            DateTime?            @map("rejected_at")
  rejectionReason       String?              @map("rejection_reason")
  approvalJournalId     String?              @unique @map("approval_journal_id")
  fiscalYear            AccountingFiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  approvalJournal       JournalEntry?        @relation("ExpenseApprovalJournal", fields: [approvalJournalId], references: [id], onDelete: Restrict)
  lines                 ExpenseLine[]
  payments              ExpensePayment[]
  attachments           ExpenseAttachment[]
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  @@index([fiscalYearId, status, date])
  @@map("expenses")
}

model ExpenseLine {
  id          String   @id @default(cuid())
  expenseId   String   @map("expense_id")
  accountId   String   @map("account_id")
  description String
  amount      Decimal  @db.Decimal(12, 2)
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([accountId])
  @@map("expense_lines")
}

model ExpenseAttachment {
  id           String   @id @default(cuid())
  expenseId    String   @map("expense_id")
  filename     String
  storagePath  String   @map("storage_path")
  checksum     String
  uploadedById String?  @map("uploaded_by_id")
  expense      Expense  @relation(fields: [expenseId], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("expense_attachments")
}

model ExpensePayment {
  id             String       @id @default(cuid())
  expenseId      String       @map("expense_id")
  moneyAccountId String       @map("money_account_id")
  journalEntryId String       @map("journal_entry_id")
  amount         Decimal      @db.Decimal(12, 2)
  date           DateTime
  transactionRef String?      @map("transaction_ref")
  reversedAt     DateTime?    @map("reversed_at")
  recordedById   String?      @map("recorded_by_id")
  expense        Expense      @relation(fields: [expenseId], references: [id], onDelete: Restrict)
  moneyAccount   MoneyAccount @relation(fields: [moneyAccountId], references: [id], onDelete: Restrict)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([expenseId, reversedAt])
  @@map("expense_payments")
}

model BankStatementImport {
  id             String              @id @default(cuid())
  moneyAccountId String              @map("money_account_id")
  filename       String
  checksum       String
  periodStart    DateTime            @map("period_start")
  periodEnd      DateTime            @map("period_end")
  importedById   String?             @map("imported_by_id")
  moneyAccount   MoneyAccount        @relation(fields: [moneyAccountId], references: [id], onDelete: Restrict)
  lines          BankStatementLine[]
  createdAt      DateTime            @default(now()) @map("created_at")

  @@unique([moneyAccountId, checksum])
  @@map("bank_statement_imports")
}

model BankStatementLine {
  id             String                @id @default(cuid())
  importId       String?               @map("import_id")
  moneyAccountId String                @map("money_account_id")
  date           DateTime
  description    String
  reference      String?
  amount         Decimal               @db.Decimal(12, 2)
  fingerprint    String
  import         BankStatementImport?  @relation(fields: [importId], references: [id], onDelete: Restrict)
  moneyAccount   MoneyAccount          @relation(fields: [moneyAccountId], references: [id], onDelete: Restrict)
  matches        ReconciliationMatch[]
  createdAt      DateTime              @default(now()) @map("created_at")

  @@unique([moneyAccountId, fingerprint])
  @@index([moneyAccountId, date])
  @@map("bank_statement_lines")
}

model ReconciliationMatch {
  id              String            @id @default(cuid())
  statementLineId String            @map("statement_line_id")
  journalLineId   String            @map("journal_line_id")
  amount          Decimal           @db.Decimal(12, 2)
  matchedById     String?           @map("matched_by_id")
  statementLine   BankStatementLine @relation(fields: [statementLineId], references: [id], onDelete: Restrict)
  journalLine     JournalLine       @relation(fields: [journalLineId], references: [id], onDelete: Restrict)
  createdAt       DateTime          @default(now()) @map("created_at")

  @@unique([statementLineId, journalLineId])
  @@index([journalLineId])
  @@map("reconciliation_matches")
}

model CashCount {
  id             String               @id @default(cuid())
  moneyAccountId String               @map("money_account_id")
  date           DateTime
  expected       Decimal              @db.Decimal(12, 2)
  counted        Decimal              @db.Decimal(12, 2)
  difference     Decimal              @db.Decimal(12, 2)
  status         ReconciliationStatus @default(PENDING_APPROVAL)
  countedById    String?              @map("counted_by_id")
  approvedById   String?              @map("approved_by_id")
  approvedAt     DateTime?            @map("approved_at")
  journalEntryId String?              @unique @map("journal_entry_id")
  moneyAccount   MoneyAccount         @relation(fields: [moneyAccountId], references: [id], onDelete: Restrict)
  journalEntry   JournalEntry?        @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  createdAt      DateTime             @default(now()) @map("created_at")

  @@index([moneyAccountId, date])
  @@map("cash_counts")
}

model AccountingAuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("accounting_audit_logs")
}

model Attendance {
  id          String           @id @default(cuid())
  enrolmentId String           @map("enrolment_id")
  termId      String           @map("term_id")
  date        DateTime
  status      AttendanceStatus
  enrolment   StudentEnrolment @relation(fields: [enrolmentId], references: [id], onDelete: Cascade)
  term        Term             @relation(fields: [termId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([enrolmentId, date])
  @@index([termId, date])
  @@map("attendance")
}

model AssessmentResult {
  id                  String            @id @default(cuid())
  enrolmentId         String            @map("enrolment_id")
  termId              String            @map("term_id")
  curriculumSubjectId String            @map("curriculum_subject_id")
  totalScore          Float             @default(0) @map("total_score")
  grade               String?
  remarks             String?
  position            Int?
  enrolment           StudentEnrolment  @relation(fields: [enrolmentId], references: [id], onDelete: Cascade)
  term                Term              @relation(fields: [termId], references: [id], onDelete: Restrict)
  curriculumSubject   CurriculumSubject @relation(fields: [curriculumSubjectId], references: [id], onDelete: Restrict)

  scores AssessmentScore[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([enrolmentId, termId, curriculumSubjectId])
  @@index([termId, curriculumSubjectId])
  @@map("assessment_results")
}

model AssessmentScore {
  resultId    String              @map("result_id")
  componentId String              @map("component_id")
  score       Float
  result      AssessmentResult    @relation(fields: [resultId], references: [id], onDelete: Cascade)
  component   AssessmentComponent @relation(fields: [componentId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([resultId, componentId])
  @@map("assessment_scores")
}

model TermReport {
  id                String           @id @default(cuid())
  enrolmentId       String           @map("enrolment_id")
  termId            String           @map("term_id")
  status            ReportStatus     @default(DRAFT)
  conduct           String?
  attitude          String?
  teacherRemarks    String?          @map("teacher_remarks")
  headteacherRemark String?          @map("headteacher_remark")
  position          Int?
  totalScore        Float?           @map("total_score")
  averageScore      Float?           @map("average_score")
  currentVersion    Int              @default(0) @map("current_version")
  enrolment         StudentEnrolment @relation(fields: [enrolmentId], references: [id], onDelete: Cascade)
  term              Term             @relation(fields: [termId], references: [id], onDelete: Restrict)

  versions ReportCardVersion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([enrolmentId, termId])
  @@index([termId, status])
  @@map("term_reports")
}

model ReportCardVersion {
  id            String     @id @default(cuid())
  reportId      String     @map("report_id")
  version       Int
  snapshot      Json
  pdfPath       String     @map("pdf_path")
  checksum      String
  publishedById String?    @map("published_by_id")
  publishedAt   DateTime   @default(now()) @map("published_at")
  report        TermReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  publishedBy   User?      @relation("ReportPublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  @@unique([reportId, version])
  @@map("report_card_versions")
}

model CalendarEvent {
  id             String       @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime     @map("start_date")
  endDate        DateTime     @map("end_date")
  type           String       @default("EVENT")
  academicYearId String       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("calendar_events")
}

model Promotion {
